<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="https://cdn.glitch.global/fd139a45-8545-4085-b451-832663448246/suitcase.png?v=1739611392498" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>TravelReady - Everything You Need Before You Go</title>
    <meta name="description" content="Smart trip preparation: packing lists, weather forecasts, visa requirements, and local travel advice -- all tailored to your exact route." />
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <div class="app-container">
      <!-- Header -->
      <header class="app-header">
        <div class="header-content">
          <h1 class="app-title">TravelReady</h1>
          <p class="app-subtitle">Everything you need before you go. Packing lists, weather forecasts, visa requirements, and local tips -- all tailored to your destination.</p>
        </div>
      </header>

      <!-- Main Form -->
      <main class="main-content">
        <form class="trip-form" action="/pack" method="post">

          <!-- Username for remembered items -->
          <div class="form-section">
            <h2 class="section-title">Who's Traveling?</h2>
            <p class="section-desc">Enter a name so we can remember your custom items for future trips.</p>
            <div class="form-group">
              <label for="username">Your Name / Username</label>
              <input type="text" id="username" name="username" placeholder="e.g. John" value="{{username}}" />
            </div>
            {{#if hasUserItems}}
            <div class="saved-notice">
              We remember you! You have <strong>{{savedItemCount}}</strong> saved item(s) from previous trips.
            </div>
            {{/if}}
          </div>

          <!-- Departure & Destination -->
          <div class="form-section">
            <h2 class="section-title">Where From & Where To</h2>
            <p class="section-desc">Tell us where you're departing from and where you're going. We'll calculate the exact documents, visa requirements, and plug adapters you need.</p>
            <div class="form-row">
              <div class="form-group form-group-half">
                <label for="departureCountry">Departing from</label>
                <select id="departureCountry" name="departureCountry">
                  <option value="">-- Select your country --</option>
                  <option value="belgium">Belgium</option>
                  <option value="netherlands">Netherlands</option>
                  <option value="france">France</option>
                  <option value="germany">Germany</option>
                  <option value="spain">Spain</option>
                  <option value="italy">Italy</option>
                  <option value="portugal">Portugal</option>
                  <option value="austria">Austria</option>
                  <option value="greece">Greece</option>
                  <option value="ireland">Ireland</option>
                  <option value="croatia">Croatia</option>
                  <option value="sweden">Sweden</option>
                  <option value="denmark">Denmark</option>
                  <option value="finland">Finland</option>
                  <option value="poland">Poland</option>
                  <option value="czech_republic">Czech Republic</option>
                  <option value="hungary">Hungary</option>
                  <option value="romania">Romania</option>
                  <option value="luxembourg">Luxembourg</option>
                  <option value="switzerland">Switzerland</option>
                  <option value="norway">Norway</option>
                  <option value="iceland">Iceland</option>
                  <option value="united_kingdom">United Kingdom</option>
                  <option value="united_states">United States</option>
                  <option value="canada">Canada</option>
                  <option value="australia">Australia</option>
                  <option value="new_zealand">New Zealand</option>
                  <option value="japan">Japan</option>
                  <option value="south_korea">South Korea</option>
                  <option value="brazil">Brazil</option>
                  <option value="south_africa">South Africa</option>
                  <option value="india">India</option>
                  <option value="mexico">Mexico</option>
                </select>
              </div>
              <div class="form-group form-group-half">
                <label for="customDestination">Going to</label>
                <input type="text" id="customDestination" name="customDestination" placeholder="e.g. Paris, Tokyo, Barcelona..." class="input-prominent" />
                <span class="form-hint">Enter a city or region for weather + local advice</span>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group form-group-half">
                <label for="destination">Destination Type</label>
                <select id="destination" name="destination" required>
                  <option value="beach">Beach / Coastal</option>
                  <option value="city" selected>City / Urban</option>
                  <option value="mountain">Mountain / Hiking</option>
                  <option value="cold_climate">Cold Climate / Winter</option>
                  <option value="tropical">Tropical</option>
                  <option value="countryside">Countryside / Rural</option>
                </select>
              </div>
              <div class="form-group form-group-half">
                <label for="international">International trip?</label>
                <select id="international" name="international">
                  <option value="no">No - Domestic</option>
                  <option value="yes">Yes - International</option>
                </select>
              </div>
            </div>
          </div>

          <!-- Duration -->
          <div class="form-section">
            <h2 class="section-title">Duration</h2>
            <div class="form-group">
              <label for="duration">How many days?</label>
              <input type="number" id="duration" name="duration" min="1" max="90" value="7" required />
            </div>
          </div>

          <!-- Weight -->
          <div class="form-section">
            <h2 class="section-title">Luggage Weight</h2>
            <div class="form-group">
              <label for="maxWeight">Maximum packing weight (kg)</label>
              <input type="number" id="maxWeight" name="maxWeight" min="1" max="100" step="0.5" value="23" required />
              <span class="form-hint">Most airlines allow 23kg for checked luggage</span>
            </div>
          </div>

          <!-- Transport -->
          <div class="form-section">
            <h2 class="section-title">Transportation</h2>
            <div class="form-group">
              <label for="transport">How are you traveling?</label>
              <div class="radio-group">
                <label class="radio-card">
                  <input type="radio" name="transport" value="plane" checked />
                  <span class="radio-label">
                    <span class="radio-icon">&#9992;</span>
                    Plane
                  </span>
                </label>
                <label class="radio-card">
                  <input type="radio" name="transport" value="car" />
                  <span class="radio-label">
                    <span class="radio-icon">&#128663;</span>
                    Car
                  </span>
                </label>
                <label class="radio-card">
                  <input type="radio" name="transport" value="train" />
                  <span class="radio-label">
                    <span class="radio-icon">&#128646;</span>
                    Train
                  </span>
                </label>
                <label class="radio-card">
                  <input type="radio" name="transport" value="bus" />
                  <span class="radio-label">
                    <span class="radio-icon">&#128653;</span>
                    Bus
                  </span>
                </label>
                <label class="radio-card">
                  <input type="radio" name="transport" value="boat" />
                  <span class="radio-label">
                    <span class="radio-icon">&#9973;</span>
                    Boat
                  </span>
                </label>
              </div>
            </div>
          </div>

          <!-- Objective -->
          <div class="form-section">
            <h2 class="section-title">Trip Objective</h2>
            <div class="form-group">
              <label for="objective">What's the purpose of your trip?</label>
              <div class="radio-group">
                <label class="radio-card">
                  <input type="radio" name="objective" value="leisure" checked />
                  <span class="radio-label">
                    <span class="radio-icon">&#127774;</span>
                    Leisure
                  </span>
                </label>
                <label class="radio-card">
                  <input type="radio" name="objective" value="business" />
                  <span class="radio-label">
                    <span class="radio-icon">&#128188;</span>
                    Business
                  </span>
                </label>
                <label class="radio-card">
                  <input type="radio" name="objective" value="adventure" />
                  <span class="radio-label">
                    <span class="radio-icon">&#127956;</span>
                    Adventure
                  </span>
                </label>
                <label class="radio-card">
                  <input type="radio" name="objective" value="cultural" />
                  <span class="radio-label">
                    <span class="radio-icon">&#127963;</span>
                    Cultural
                  </span>
                </label>
                <label class="radio-card">
                  <input type="radio" name="objective" value="romantic" />
                  <span class="radio-label">
                    <span class="radio-icon">&#10084;</span>
                    Romantic
                  </span>
                </label>
                <label class="radio-card">
                  <input type="radio" name="objective" value="cycling" />
                  <span class="radio-label">
                    <span class="radio-icon">&#128692;</span>
                    Cycling
                  </span>
                </label>
                <label class="radio-card">
                  <input type="radio" name="objective" value="hiking" />
                  <span class="radio-label">
                    <span class="radio-icon">&#129406;</span>
                    Hiking
                  </span>
                </label>
                <label class="radio-card">
                  <input type="radio" name="objective" value="skiing" />
                  <span class="radio-label">
                    <span class="radio-icon">&#9975;</span>
                    Skiing
                  </span>
                </label>
                <label class="radio-card">
                  <input type="radio" name="objective" value="water_sports" />
                  <span class="radio-label">
                    <span class="radio-icon">&#127946;</span>
                    Water Sports
                  </span>
                </label>
              </div>
            </div>
          </div>

          <!-- Submit -->
          <div class="form-section form-actions">
            <button type="submit" class="btn btn-primary btn-large">Get Me TravelReady</button>
          </div>
        </form>
      </main>

      <footer class="app-footer">
        <p>TravelReady &mdash; Everything you need before you go.</p>
      </footer>
    </div>
  </body>
</html>
